{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Streamlit",
      "type": "shell",
      "command": "uv run streamlit run src/app.py",
      "group": "build",
      "presentation": { "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Start Watcher",
      "type": "shell",
      "command": "uv run python -m src.watcher",
      "group": "build",
      "presentation": { "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Start All",
      "dependsOn": ["Start Streamlit", "Start Watcher"],
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}
